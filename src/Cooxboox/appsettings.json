{
  "AllowedHosts": "*",
  "Api": {
    "Title": "Cooxboox API",
    "Version": "0.1.0",
    "Build": null
  },
  "Authentication": {
    "AccessToken": {
      "Type": "at+jwt",
      "LifetimeSeconds": 300
    }
  },
  "Cookies": {
    "RefreshToken": {
      "HttpOnly": true,
      "MaxAge": "7.00:00:00",
      "SameSite": "Strict",
      "Secure": true
    },
    "Session": {
      "SameSite": "Strict"
    }
  },
  "Cors": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": [],
    "AllowAnyMethod": false,
    "AllowedMethods": [],
    "AllowAnyHeader": false,
    "AllowedHeaders": [],
    "AllowCredentials": false
  },
  "Krakenar": {
    "Realm": "cooxboox"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Retry": {
    "Algorithm": "None",
    "Delay": 0,
    "ExponentialBase": 0,
    "RandomVariation": 0,
    "MaximumRetries": 0,
    "MaximumDelay": 0
  }
}
