<!doctype html>
<html lang="@(Model.Locale?.Code)">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(Model.Resource("MultiFactorAuthentication_Subject"))</title>
  </head>
  <body style="margin: 0; padding: 0; background-color: #f6f7f9; font-family: Arial, Helvetica, sans-serif; color: #1f2933">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color: #f6f7f9; margin: 0; padding: 24px 0">
      <tr>
        <td align="center">
          <table
            role="presentation"
            width="100%"
            cellspacing="0"
            cellpadding="0"
            style="max-width: 600px; background-color: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb"
          >
            <tr>
              <td style="padding: 32px 32px 16px 32px; text-align: center">
                <h1 style="margin: 0; font-size: 24px; line-height: 32px; color: #111827">@(Model.Resource("MultiFactorAuthenticationEmail_Title"))</h1>
              </td>
            </tr>

            <tr>
              <td style="padding: 16px 32px 0 32px">
                <p style="margin: 0 0 16px 0; font-size: 16px; line-height: 24px; color: #374151">
                  @(Model.Resource("MultiFactorAuthenticationEmail_CallToAction"))
                </p>

                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin: 0 0 24px 0">
                  <tr>
                    <td align="center" style="background-color: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 10px; padding: 20px">
                      <div
                        style="
                          font-size: 32px;
                          line-height: 40px;
                          letter-spacing: 8px;
                          font-weight: bold;
                          color: #111827;
                          font-family: Arial, Helvetica, sans-serif;
                        "
                      >
                        @(Model.Variable("OneTimePassword"))
                      </div>
                    </td>
                  </tr>
                </table>

                <p style="margin: 0 0 16px 0; font-size: 16px; line-height: 24px; color: #374151">@(Model.Resource("MultiFactorAuthenticationEmail_Valid"))</p>

                <p style="margin: 0 0 28px 0; font-size: 14px; line-height: 21px; color: #6b7280">@(Model.Resource("MultiFactorAuthenticationEmail_Ignore"))</p>
              </td>
            </tr>

            <tr>
              <td style="padding: 20px 32px; background-color: #f9fafb; text-align: center">
                <p style="margin: 0; font-size: 12px; line-height: 18px; color: #9ca3af">@(Model.Resource("NoReply"))</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
