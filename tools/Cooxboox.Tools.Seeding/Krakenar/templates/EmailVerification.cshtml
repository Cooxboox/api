<!doctype html>
<html lang="@(Model.Locale?.Code)">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(Model.Resource("EmailVerification_Subject"))</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f6f7f9; font-family: Arial, Helvetica, sans-serif; color: #1f2933">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color: #f6f7f9; margin: 0; padding: 24px 0">
    <tr>
      <td align="center">
        <table role="presentation"
               width="100%"
               cellspacing="0"
               cellpadding="0"
               style="max-width: 600px; background-color: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb">
          <tr>
            <td style="padding: 32px 32px 16px 32px; text-align: center">
              <h1 style="margin: 0; font-size: 24px; line-height: 32px; color: #111827">@(Model.Resource("EmailVerification_Title"))</h1>
            </td>
          </tr>

          <tr>
            <td style="padding: 16px 32px 0 32px">
              <p style="margin: 0 0 16px 0; font-size: 16px; line-height: 24px; color: #374151">@(Model.Resource("EmailVerification_Requested"))</p>

              <p style="margin: 0 0 24px 0; font-size: 16px; line-height: 24px; color: #374151">@(Model.Resource("EmailVerification_CallToAction"))</p>

              <table role="presentation" cellspacing="0" cellpadding="0" style="margin: 0 0 24px 0">
                <tr>
                  <td align="center" style="border-radius: 8px; background-color: #2563eb">
                    <a href="@(Model.Variable("Token"))"
                       style="
                          display: inline-block;
                          padding: 14px 22px;
                          font-size: 16px;
                          line-height: 20px;
                          color: #ffffff;
                          text-decoration: none;
                          font-weight: bold;
                          border-radius: 8px;
                        ">
                      @(Model.Resource("Continue"))
                    </a>
                  </td>
                </tr>
              </table>

              <p style="margin: 0 0 16px 0; font-size: 14px; line-height: 21px; color: #6b7280">@(Model.Resource("EmailVerification_Help"))</p>

              <p style="margin: 0 0 24px 0; font-size: 14px; line-height: 21px; word-break: break-all; color: #2563eb">
                <a href="@(Model.Variable("Token"))" style="color: #2563eb; text-decoration: underline">@(Model.Variable("Token"))</a>
              </p>

              <p style="margin: 0 0 28px 0; font-size: 14px; line-height: 21px; color: #6b7280">@(Model.Resource("EmailVerification_Ignore"))</p>
            </td>
          </tr>

          <tr>
            <td style="padding: 20px 32px; background-color: #f9fafb; text-align: center">
              <p style="margin: 0; font-size: 12px; line-height: 18px; color: #9ca3af">@(Model.Resource("NoReply"))</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
